<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Кнопка назад -->
    <TextView
        android:id="@+id/btn_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="‹"
        android:textSize="32sp"
        android:textColor="#000000"
        android:padding="16dp"/>

    <!-- Заголовок по центру -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Введите код из E-mail"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:gravity="center"/>

    <!-- 4 ячейки кода -->
    <LinearLayout
        android:id="@+id/code_cells"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center_horizontal"
        android:gravity="center">

        <TextView android:id="@+id/cell_1"
            android:layout_width="60dp" android:layout_height="60dp"
            android:background="@drawable/bg_code_cell"
            android:gravity="center"
            android:textSize="24sp" android:textColor="#000000"
            android:layout_margin="6dp"/>
        <TextView android:id="@+id/cell_2"
            android:layout_width="60dp" android:layout_height="60dp"
            android:background="@drawable/bg_code_cell"
            android:gravity="center"
            android:textSize="24sp" android:textColor="#000000"
            android:layout_margin="6dp"/>
        <TextView android:id="@+id/cell_3"
            android:layout_width="60dp" android:layout_height="60dp"
            android:background="@drawable/bg_code_cell"
            android:gravity="center"
            android:textSize="24sp" android:textColor="#000000"
            android:layout_margin="6dp"/>
        <TextView android:id="@+id/cell_4"
            android:layout_width="60dp" android:layout_height="60dp"
            android:background="@drawable/bg_code_cell"
            android:gravity="center"
            android:textSize="24sp" android:textColor="#000000"
            android:layout_margin="6dp"/>
    </LinearLayout>

    <!-- Таймер -->
    <TextView
        android:id="@+id/tv_timer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="14sp"
        android:textColor="#939393"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Кастомная клавиатура -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:background="#F2F2F7"
        android:padding="8dp">

        <TextView android:id="@+id/key_1" style="@style/KeyStyle" android:text="1"/>
        <TextView android:id="@+id/key_2" style="@style/KeyStyle" android:text="2\nABC"/>
        <TextView android:id="@+id/key_3" style="@style/KeyStyle" android:text="3\nDEF"/>
        <TextView android:id="@+id/key_4" style="@style/KeyStyle" android:text="4\nGHI"/>
        <TextView android:id="@+id/key_5" style="@style/KeyStyle" android:text="5\nJKL"/>
        <TextView android:id="@+id/key_6" style="@style/KeyStyle" android:text="6\nMNO"/>
        <TextView android:id="@+id/key_7" style="@style/KeyStyle" android:text="7\nPQRS"/>
        <TextView android:id="@+id/key_8" style="@style/KeyStyle" android:text="8\nTUV"/>
        <TextView android:id="@+id/key_9" style="@style/KeyStyle" android:text="9\nWXYZ"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_columnWeight="1"/>
        <TextView android:id="@+id/key_0" style="@style/KeyStyle" android:text="0"/>
        <TextView android:id="@+id/key_del" style="@style/KeyStyle" android:text="⌫"/>

    </GridLayout>

</LinearLayout>