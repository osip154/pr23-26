<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Заголовок + Пропустить -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Создание карты пациента"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_toStartOf="@+id/btn_skip"
                android:layout_alignParentStart="true"/>

            <TextView
                android:id="@+id/btn_skip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Пропустить"
                android:textColor="#2563EB"
                android:textSize="16sp"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>

        <!-- Описание -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Без карты пациента вы не сможете заказать анализы.\n\nВ картах пациентов будут храниться результаты анализов вас и ваших близких."
            android:textSize="14sp"
            android:textColor="#939393"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"/>

        <!-- Имя -->
        <EditText
            android:id="@+id/et_name"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Имя"
            android:textSize="16sp"
            android:textColor="#000000"
            android:textColorHint="#AAAAAA"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textPersonName"
            android:layout_marginBottom="12dp"/>

        <!-- Отчество -->
        <EditText
            android:id="@+id/et_patronymic"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Отчество"
            android:textSize="16sp"
            android:textColor="#000000"
            android:textColorHint="#AAAAAA"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textPersonName"
            android:layout_marginBottom="12dp"/>

        <!-- Фамилия -->
        <EditText
            android:id="@+id/et_surname"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Фамилия"
            android:textSize="16sp"
            android:textColor="#000000"
            android:textColorHint="#AAAAAA"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textPersonName"
            android:layout_marginBottom="12dp"/>

        <!-- Дата рождения -->
        <TextView
            android:id="@+id/et_birthdate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Дата рождения"
            android:textSize="16sp"
            android:textColor="#000000"
            android:textColorHint="#AAAAAA"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp"/>

        <!-- Пол -->
        <Spinner
            android:id="@+id/spinner_gender"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="32dp"/>

        <!-- Кнопка Создать -->
        <Button
            android:id="@+id/btn_create"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Создать"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button"
            android:enabled="false"/>

    </LinearLayout>
</ScrollView>