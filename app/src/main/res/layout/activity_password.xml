<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="24dp">

    <TextView
        android:id="@+id/btn_skip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Пропустить"
        android:textColor="#2563EB"
        android:textSize="16sp"
        android:gravity="end"
        android:layout_marginTop="8dp"/>

    <!-- Отступ сверху -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Создайте пароль"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:gravity="center"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Для защиты ваших персональных данных"
        android:textSize="14sp"
        android:textColor="#939393"
        android:gravity="center"
        android:layout_marginTop="8dp"/>

    <LinearLayout
        android:id="@+id/dots_password"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="24dp"/>

    <!-- Отступ между точками и клавиатурой -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"/>

    <!-- Ряд 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        android:layout_marginBottom="8dp">
        <TextView android:id="@+id/pk_1" style="@style/PinKeyStyle" android:text="1"/>
        <TextView android:id="@+id/pk_2" style="@style/PinKeyStyle" android:text="2"/>
        <TextView android:id="@+id/pk_3" style="@style/PinKeyStyle" android:text="3"/>
    </LinearLayout>

    <!-- Ряд 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        android:layout_marginBottom="8dp">
        <TextView android:id="@+id/pk_4" style="@style/PinKeyStyle" android:text="4"/>
        <TextView android:id="@+id/pk_5" style="@style/PinKeyStyle" android:text="5"/>
        <TextView android:id="@+id/pk_6" style="@style/PinKeyStyle" android:text="6"/>
    </LinearLayout>

    <!-- Ряд 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        android:layout_marginBottom="8dp">
        <TextView android:id="@+id/pk_7" style="@style/PinKeyStyle" android:text="7"/>
        <TextView android:id="@+id/pk_8" style="@style/PinKeyStyle" android:text="8"/>
        <TextView android:id="@+id/pk_9" style="@style/PinKeyStyle" android:text="9"/>
    </LinearLayout>

    <!-- Ряд 4 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        android:layout_marginBottom="32dp">
        <View
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="10dp"/>
        <TextView android:id="@+id/pk_0" style="@style/PinKeyStyle" android:text="0"/>
        <TextView android:id="@+id/pk_del" style="@style/PinKeyStyle" android:text="⌫"/>
    </LinearLayout>

</LinearLayout>