<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Основной контент со скроллом -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Поиск -->
            <EditText
                android:id="@+id/et_search"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="🔍  Искать анализы"
                android:textSize="15sp"
                android:textColorHint="#AAAAAA"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="text"
                android:layout_marginBottom="20dp"/>

            <!-- Акции и новости -->
            <TextView
                android:id="@+id/tv_news_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Акции и новости"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="12dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:id="@+id/news_container"
                    android:layout_width="wrap_content"
                    android:layout_height="140dp"
                    android:orientation="horizontal"/>

            </HorizontalScrollView>

            <!-- Каталог анализов -->
            <TextView
                android:id="@+id/tv_catalog_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Каталог анализов"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="12dp"/>

            <!-- Табы -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tab_popular"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Популярные"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_tab_active"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tab_covid"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Covid"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="14sp"
                    android:textColor="#000000"
                    android:background="@drawable/bg_tab_inactive"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tab_complex"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Комплексные"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="14sp"
                    android:textColor="#000000"
                    android:background="@drawable/bg_tab_inactive"/>

            </LinearLayout>

            <!-- Список анализов -->
            <LinearLayout
                android:id="@+id/analysis_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <Button
                android:id="@+id/btn_payment"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Добавить платёж"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_button"
                android:layout_marginTop="16dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- Нижнее меню -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/menu_analysis"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔬" android:textSize="20sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Анализы" android:textSize="11sp" android:textColor="#2563EB"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/menu_results"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📋" android:textSize="20sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Результаты" android:textSize="11sp" android:textColor="#939393"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/menu_support"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="💬" android:textSize="20sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Поддержка" android:textSize="11sp" android:textColor="#939393"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/menu_profile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👤" android:textSize="20sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Профиль" android:textSize="11sp" android:textColor="#939393"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>