<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Градиентный фон -->
    <item>
        <shape>
            <gradient
                android:startColor="#4EA4E8"
                android:centerColor="#3B72E3"
                android:endColor="#2944DD"
                android:angle="45"/>
        </shape>
    </item>

    <!-- Логотип с текстом по центру -->
    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/ic_splash_logo"/>
    </item>

</layer-list>